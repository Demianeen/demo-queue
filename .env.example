# Local development uses the deployment selected by Convex.
# Vercel production and preview builds receive this value from `convex deploy`.
CONVEX_DEPLOYMENT=<dev-or-prod-deployment>
NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# Optional. Used only by queue helper output when printing full admin URLs.
# Locally this defaults to http://localhost:3000. Production defaults to the
# stable Vercel alias when using `pnpm queue:prod`.
DEMO_QUEUE_SITE_URL=http://localhost:3000

# Native Google Sheet export runs inside Convex. Configure these with
# `pnpm exec convex env set`, not in this local Next.js env file:
# GOOGLE_OAUTH_CLIENT_ID
# GOOGLE_OAUTH_CLIENT_SECRET
# GOOGLE_OAUTH_REFRESH_TOKEN
# GOOGLE_DRIVE_FOLDER_ID (folder in the connected account's My Drive)
